{
    "$schema": "https://turborepo.dev/schema.json",
    "ui": "tui",
    "tasks": {
      "build": {
        "dependsOn": ["^build"],
        "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**"]
      },
      "check-types": {
        "dependsOn": ["^check-types"]
      },
      "dev": {
        "persistent": true,
        "cache": false
      },
      "lint": {
        "dependsOn": ["^lint"]
      },
      "lint:fix": {
        "dependsOn": ["^lint:fix"]
      },
      "format": {
        "dependsOn": ["^format"]
      }
    }
  }