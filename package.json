{
  "name": "fila-saude",
  "version": "1.0.0",
  "description": "Vamos tornar a espera nos postos de saúde mais tranquila? 💙",
  "packageManager": "npm@11.16.0",
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "commitizen": "^4.3.2",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "turbo": "^2.10.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write",
    "test": "npm -w @fila-saude/api run test",
    "test:watch": "npm -w @fila-saude/api run test:watch",
    "test:coverage": "npm -w @fila-saude/api run test:coverage",
    "services:up": "npm -w @fila-saude/api run services:up",
    "services:stop": "npm -w @fila-saude/api run services:stop",
    "services:down": "npm -w @fila-saude/api run services:down",
    "db:push": "npm -w @fila-saude/api run db:push",
    "db:generate": "npm -w @fila-saude/api run db:generate",
    "db:migrate": "npm -w @fila-saude/api run db:migrate",
    "db:push:test": "npm -w @fila-saude/api run db:push:test",
    "db:generate:test": "npm -w @fila-saude/api run db:generate:test",
    "db:migrate:test": "npm -w @fila-saude/api run db:migrate:test",
    "prepare": "husky",
    "commit": "cz"
  },
  "engines": {
    "node": "24.x"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryansldev/fila-saude.git"
  },
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/ryansldev/fila-saude/issues"
  },
  "homepage": "https://github.com/ryansldev/fila-saude#readme",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
